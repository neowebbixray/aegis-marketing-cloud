# ─── Application ────────────────────────────────────────────
APP_NAME="Aegis Marketing Cloud"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-to-a-long-random-string
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aegis:aegis_secret@localhost:5432/aegis
DATABASE_SYNC_URL=postgresql://aegis:aegis_secret@localhost:5432/aegis
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:aegis_redis@localhost:6379/0
REDIS_SESSION_URL=redis://:aegis_redis@localhost:6379/1
REDIS_CACHE_URL=redis://:aegis_redis@localhost:6379/2

# ─── Qdrant ─────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=amc_

# ─── MinIO ──────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=aegis_minio
MINIO_SECRET_KEY=aegis_minio_secret
MINIO_BUCKET_ASSETS=aegis-assets
MINIO_BUCKET_MEDIA=aegis-media
MINIO_BUCKET_BACKUPS=aegis-backups
MINIO_USE_SSL=false

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_URL=amqp://aegis:aegis_rabbit@localhost:5672/
RABBITMQ_WORKFLOW_QUEUE=amc-workflows
RABBITMQ_NOTIFICATION_QUEUE=amc-notifications

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_ISSUER_NAME="Aegis Marketing Cloud"
OAUTH_REDIRECT_URL=http://localhost:8000/api/v1/auth/oauth/callback

# ─── AI / LLM ──────────────────────────────────────────────
AI_PROVIDER=nvidia-nim
AI_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ─── Hermes Agent ──────────────────────────────────────────
HERMES_AGENT_ENABLED=true
HERMES_PROFILE=amc-default

# ─── n8n ────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ─── Email / SMTP ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aegismc.com
SMTP_TLS=false

# ─── Monitoring ────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
OTEL_SERVICE_NAME=aegis-marketing-cloud
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Storage ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
STORAGE_BACKEND=local

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_SECOND=10

# ─── Feature Flags ─────────────────────────────────────────
FEATURE_AI_AGENTS=true
FEATURE_MARKETPLACE=false
FEATURE_WHITE_LABEL=false
FEATURE_BILLING_ENABLED=false
