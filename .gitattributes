# ─── Auto-detect text files and normalize to LF ──────────────
* text=auto

# ─── Explicitly declare binary files ─────────────────────────
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
*.mp4 binary
*.webm binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.ico binary

# ─── Python ──────────────────────────────────────────────────
*.py text diff=python
*.pyi text diff=python
*.pyx text diff=python
*.pxd text diff=python
*.toml text
*.cfg text
*.ini text
*.rst text

# ─── JavaScript / TypeScript ─────────────────────────────────
*.js text
*.jsx text
*.ts text diff=typescript
*.tsx text
*.json text
*.html text
*.css text
*.scss text
*.less text

# ─── Shell / Scripts ─────────────────────────────────────────
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
Dockerfile text
*.yml text
*.yaml text
*.env text
*.env.example text

# ─── Markdown / Docs ─────────────────────────────────────────
*.md text diff=markdown
*.mdx text

# ─── SQL ─────────────────────────────────────────────────────
*.sql text

# ─── GraphQL ─────────────────────────────────────────────────
*.graphql text
*.gql text

# ─── Docker ──────────────────────────────────────────────────
.dockerignore text
