# =============================================================================
# Aegis Marketing Cloud — Environment Configuration Example
# Copy this file to .env and fill in your values.
# =============================================================================

# ─── Application ────────────────────────────────────────────
APP_NAME="Aegis Marketing Cloud"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
TRUSTED_HOSTS=localhost,127.0.0.1

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aegis:aegis_secret@localhost:5432/aegis
DATABASE_SYNC_URL=postgresql://aegis:aegis_secret@localhost:5432/aegis
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:aegis_redis@localhost:6379/0
REDIS_SESSION_URL=redis://:aegis_redis@localhost:6379/1
REDIS_CACHE_URL=redis://:aegis_redis@localhost:6379/2

# ─── Qdrant (Vector Store) ──────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_HTTPS=false

# ─── MinIO / S3 ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=aegis_minio
MINIO_SECRET_KEY=aegis_minio_secret
MINIO_USE_SSL=false
MINIO_BUCKET_ASSETS=aegis-assets
MINIO_BUCKET_MEDIA=aegis-media
MINIO_BUCKET_BACKUPS=aegis-backups

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_URL=amqp://aegis:aegis_rabbit@localhost:5672/
RABBITMQ_WORKFLOW_QUEUE=amc-workflows
RABBITMQ_NOTIFICATION_QUEUE=amc-notifications

# ─── Auth / JWT ────────────────────────────────────────────
# RS256 (asymmetric) is used for JWT signing per docs spec.
# RSA key pairs are auto-generated on first run and stored in app/core/keys/.
# In production, store the private key in HashiCorp Vault instead.
JWT_ALGORITHM=RS256
JWT_KEY_ID=default
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_ISSUER_NAME="Aegis Marketing Cloud"

# ─── Encryption (pgcrypto) ─────────────────────────────────
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# ─── SSO / OAuth ───────────────────────────────────────────
SSO_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ─── SAML ──────────────────────────────────────────────────
SAML_IDP_METADATA_URL=
SAML_IDP_ENTITY_ID=
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=
SAML_SP_X509_CERT=
SAML_SP_PRIVATE_KEY=

# ─── Stripe / Billing ──────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=

# ─── AI / LLM ──────────────────────────────────────────────
AI_PROVIDER=nvidia-nim
AI_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ─── Embeddings ────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_ENDPOINT=
EMBEDDING_DIMENSION=384
EMBEDDING_API_KEY=

# ─── Knowledge / Chunking ──────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ─── Celery (optional) ─────────────────────────────────────
CELERY_BROKER_URL=redis://:aegis_redis@localhost:6379/0

# ─── n8n Workflow Engine ───────────────────────────────────
N8N_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ─── Email / SMTP ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aegismc.com
SMTP_TLS=false

# ─── Monitoring / Error Tracking ───────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
PROMETHEUS_ENABLED=true
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
OTEL_SERVICE_NAME=aegis-marketing-cloud
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Storage ───────────────────────────────────────────────
MEDIA_LIBRARY_ROOT=media-library
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
STORAGE_BACKEND=local

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ─── Feature Flags ─────────────────────────────────────────
FEATURE_AI_AGENTS=true
FEATURE_MARKETPLACE=false
FEATURE_WHITE_LABEL=false
FEATURE_BILLING_ENABLED=false
