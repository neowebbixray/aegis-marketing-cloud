# Aegis Marketing Cloud — Frontend Environment Configuration
# Copy this file to .env.local and fill in your values.
#
# These variables are available at build time in Next.js via
# the NEXT_PUBLIC_ prefix convention.  Variables without
# NEXT_PUBLIC_ are server-side only.

# ─── API Backend ────────────────────────────────────────────
# Public URL of the FastAPI backend (used client-side)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Authentication ─────────────────────────────────────────
# SSO redirect endpoint (must match backend config)
NEXT_PUBLIC_SSO_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# ─── Application ────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Aegis Marketing Cloud
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development

# ─── Feature Flags ──────────────────────────────────────────
NEXT_PUBLIC_FEATURE_AI_AGENTS=true
NEXT_PUBLIC_FEATURE_MARKETPLACE=false
NEXT_PUBLIC_FEATURE_WHITE_LABEL=false
NEXT_PUBLIC_FEATURE_BILLING_ENABLED=false

# ─── Analytics / Monitoring ─────────────────────────────────
# (Optional) PostHog / Sentry / etc.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_SENTRY_DSN=
