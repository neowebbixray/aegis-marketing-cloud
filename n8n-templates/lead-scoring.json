          {
            "node": "Calculate Lead Score",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Calculate Lead Score": {
      "main": [
        [
          {
            "node": "Fetch Deals Matching Contacts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Deals Matching Contacts": {
      "main": [
        [
          {
            "node": "Update Deal Stage in Aegis",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
