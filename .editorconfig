# EditorConfig — https://editorconfig.org
# Maintains consistent coding styles across all editors and IDEs.

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.{md,rst}]
trim_trailing_whitespace = false

[{Makefile,Dockerfile,.dockerignore,.gitignore,.gitattributes,.editorconfig}]
indent_style = tab
indent_size = unset

[*.bat]
end_of_line = crlf

[*.ps1]
end_of_line = crlf
